# EMLyzer - .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Database
backend/data/
*.db
*.sqlite
*.sqlite3

# Upload e report generati (dati utente, mai in repo)
backend/uploads/
backend/reports/

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Log
*.log

# Varianti dotenv
.env.*
.env.local

# Test artifacts
.coverage
htmlcov/

# File temporanei degli script di avvio
*.tmp

# Certificati e chiavi private
*.pem
*.key