# EMLyzer - .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
.env.local
.env.*.local
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Database
backend/data/
*.db
*.sqlite
*.sqlite3

# Upload e report generati (dati utente, mai in repo)
backend/uploads/
backend/reports/

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code (file locali, non per il repo)
.claude/
claude.md
CLAUDE.md

# Log
*.log
