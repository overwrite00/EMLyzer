# EMLyzer - Configurazione Backend
# Copia questo file in .env e personalizza i valori
# Le chiavi API sono TUTTE opzionali: lascia vuoto per disabilitare il connettore

# --- App ---
DEBUG=false

# --- Upload ---
MAX_UPLOAD_SIZE_MB=25

# --- API Keys opzionali (plugin di reputazione) ---
# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# PhishTank: https://www.phishtank.com/api_register.php
PHISHTANK_API_KEY=

# --- Database ---
# Default: SQLite locale (non modificare se non sai cosa fai)
# Per PostgreSQL: postgresql+asyncpg://user:password@localhost/omf
# DATABASE_URL=sqlite+aiosqlite:///./data/emlyzer.db

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Lingua interfaccia ---
# it = italiano (default)
# en = english
LANGUAGE=it
