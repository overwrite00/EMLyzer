# EMLyzer - Configurazione Backend
# Copia questo file in .env e personalizza i valori
# Le chiavi API sono TUTTE opzionali: lascia vuoto per disabilitare il connettore

# --- App ---
DEBUG=false

# --- Upload ---
MAX_UPLOAD_SIZE_MB=25

# --- API Keys opzionali (plugin di reputazione) ---
# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# PhishTank: https://www.phishtank.com/api_register.php
PHISHTANK_API_KEY=

# abuse.ch (URLhaus + ThreatFox + MalwareBazaar): https://auth.abuse.ch/ (gratuito)
# Una sola chiave copre tutti e tre i servizi abuse.ch
ABUSECH_API_KEY=

# MalwareBazaar (chiave legacy — usa ABUSECH_API_KEY per i nuovi account)
MALWAREBAZAAR_API_KEY=

# CIRCL Passive DNS: https://www.circl.lu/pdns/ (gratuito con registrazione)
# Formato: username:password  (es. CIRCL_API_KEY=mio_utente:mia_password)
CIRCL_API_KEY=

# GreyNoise Community: https://www.greynoise.io/ (100 req/g free)
GREYNOISE_API_KEY=

# URLScan.io: https://urlscan.io/user/signup (100 req/h free — opzionale per search)
URLSCAN_API_KEY=

# Pulsedive: https://pulsedive.com/dashboard/ (30 req/min free)
PULSEDIVE_API_KEY=

# Criminal IP: https://www.criminalip.io/ (free tier)
CRIMINALIP_API_KEY=

# SecurityTrails: https://securitytrails.com/app/account (50 req/mese free)
SECURITYTRAILS_API_KEY=

# Hybrid Analysis: https://www.hybrid-analysis.com/signup (gratuito con registrazione)
HYBRID_ANALYSIS_API_KEY=

# LanguageTool — rilevamento errori grammaticali (opzionale)
# Lasciare vuoto per disabilitare.
# URL server locale (Java): http://localhost:8081
# URL pubblico con limiti: https://api.languagetool.org/v2/check
LANGUAGETOOL_API_URL=

# --- Database ---
# Default: SQLite locale (non modificare se non sai cosa fai)
# Per PostgreSQL: postgresql+asyncpg://user:password@localhost/omf
# DATABASE_URL=sqlite+aiosqlite:///./data/emlyzer.db

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Lingua interfaccia ---
# it = italiano (default)
# en = english
LANGUAGE=it
