    },
    "issue_2_threatfox_result_parsing": {
      "title": "ThreatFox returns 'illegal_search_term' and 'no_result' (singular)",
      "workaround": "Both must be added to 'no result' cases in _parse_threatfox_result",
      "impact": "malformed URLs could show status instead of clean verdict"
    },
    "issue_3_securitytrails_no_free": {
      "title": "SecurityTrails has no free tier anymore (trial only)",
      "impact": "Service returns skipped unless valid credentials",
      "recommendation": "Mark as informational, not critical"
    },
    "issue_4_pulsedive_rate_limit": {
      "title": "Pulsedive free tier reduced to 10 req/day (March 2024)",
      "impact": "Barely usable for production",
      "recommendation": "Consider removing from automatic checks"
    },
    "issue_5_slow_phase_placeholder_finalization": {
      "title": "finalize_fast_only() must be called when has_slow=false",
