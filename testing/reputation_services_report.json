  "architecture": {
    "two_phase_system": {
      "phase_1_fast": {
        "description": "Executes within 50 seconds (browser timeout safe)",
        "services": 15,
        "typical_response_time": "5-15 seconds",
        "blocking": true,
        "endpoint": "POST /api/reputation/{job_id}",
        "includes_slow_indicators_extraction": true
      },
      "phase_2_slow": {
        "description": "Runs in background after phase 1 returns",
        "services": 2,
        "uses_background_tasks": true,
        "timeout_per_request": 8,
        "indicator_selection": "priority-based (only high-value indicators)",
        "max_urls_slow": 4,
        "max_ips_slow": "all from received headers + x_originating_ip",
        "frontend_polling": "GET /api/analysis/{job_id} every 5 seconds"
      }
    },
    "indicator_extraction": {
      "fast_phase_indicators": {
        "ips": "all received hops + x_originating_ip + URL hosts + resolved IPs",
        "urls": "all discovered URLs",
        "hashes": "all attachment SHA256s"
      },
      "slow_phase_indicators": {
        "ips": "ONLY received hops + x_originating_ip (not resolved_ip to avoid CDN IPs)",
        "urls": "max 4, only suspicious ones (shortener, new domain, IP direct, punycode, score>=25, obfuscated)",
        "hashes": "all attachments"
      }
    },
    "rate_limiting": {
      "implementation": "thread-safe per-service locks",
      "mechanism": "threading.Lock + minimum interval between requests",
      "intervals_by_service": {
        "virustotal": 15.5,
        "abuseipdb": 1.1,
        "crtsh": 2.5,
        "malwarebazaar": 0.7,
        "phishtank": 0.5,
        "asnlookup": 0.3,
        "redirectchain": 0.2,
        "shodaninternetdb": 0.3,
        "urlhaus": 0.3,
        "threatfox": 0.3,
        "openphish": 0.0,
        "spamhaus": 0.0
      },
      "retry_strategy": "backoff 2s/4s on 429/502/503/504"
    },
    "caching": {
      "spamhaus_drop": {
        "location": "backend/data/cache/spamhaus_drop.json",
        "ttl_hours": 24,
        "format": "CIDR networks as JSON list"
      },
      "openphish_feed": {
        "location": "backend/data/cache/openphish_feed.json",
        "ttl_hours": 12,
        "format": "URLs as JSON list"
      },
      "fallback_on_failure": true,
      "fallback_behavior": "use stale cache if download fails"
    }
  },
